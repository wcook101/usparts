[Unit]
Description=USParts development server
After=network.target postgresql.service

[Service]
Type=simple
User=bill
WorkingDirectory=/home/bill/usparts
EnvironmentFile=/home/bill/usparts/.env
ExecStart=/usr/bin/npm run dev
Restart=on-failure
RestartSec=5
StandardOutput=append:/home/bill/usparts-dev.log
StandardError=append:/home/bill/usparts-dev.log

[Install]
WantedBy=multi-user.target
